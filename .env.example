# IPFS Configuration
# Choose one provider: 'pinata' or 'nft-storage' (default)
NEXT_PUBLIC_IPFS_PROVIDER=nft-storage

# NFT.storage (free IPFS hosting)
# Get key from: https://nft.storage
NEXT_PUBLIC_NFT_STORAGE_KEY=your_nft_storage_api_key_here

# Pinata (alternative IPFS provider)
# Get keys from: https://www.pinata.cloud
NEXT_PUBLIC_PINATA_API_KEY=your_pinata_api_key_here
PINATA_API_SECRET=your_pinata_api_secret_here

# NFT Smart Contract Configuration
# Set your deployed contract address and network
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_NFT_CONTRACT_CHAIN_ID=1

# Contract ABI (paste your contract's ABI as JSON)
# This will need to be set in code or loaded dynamically
NEXT_PUBLIC_NFT_CONTRACT_ABI=

# Image Generation (existing configuration)
NEXT_PUBLIC_FREEPIK_API_KEY=your_freepik_key_if_using_mystic_mode
HF_API_TOKEN=your_huggingface_token_for_stable_diffusion
